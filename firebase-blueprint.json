{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "User information and roles.",
      "type": "object",
      "properties": {
        "nom": { "type": "string" },
        "prenom": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "gerant", "client"] },
        "phone": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["nom", "prenom", "email", "role"]
    },
    "hotels": {
      "title": "Hotel",
      "description": "Hotel managed by users.",
      "type": "object",
      "properties": {
        "nom": { "type": "string" },
        "adresse": { "type": "string" },
        "description": { "type": "string" },
        "gerant_id": { "type": "string" },
        "stars": { "type": "number" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" }
      },
      "required": ["nom", "adresse", "gerant_id"]
    },
    "rooms": {
      "title": "Room",
      "description": "Rooms in a hotel.",
      "type": "object",
      "properties": {
        "numero": { "type": "string" },
        "type": { "type": "string" },
        "prix": { "type": "number" },
        "capacite": { "type": "number" },
        "statut": { "type": "string", "enum": ["libre", "occupée", "maintenance"] },
        "description": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["numero", "type", "prix", "capacite"]
    },
    "reservations": {
      "title": "Reservation",
      "description": "Bookings for rooms.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "hotel_id": { "type": "string" },
        "chambre_id": { "type": "string" },
        "date_arrivee": { "type": "string" },
        "date_depart": { "type": "string" },
        "statut": { "type": "string", "enum": ["en_attente", "confirmee", "annulee"] },
        "demande_speciale": { "type": "string" }
      },
      "required": ["user_id", "hotel_id", "chambre_id", "date_arrivee", "date_depart"]
    },
    "reviews": {
      "title": "Review",
      "description": "Hotel feedback.",
      "type": "object",
      "properties": {
        "hotel_id": { "type": "string" },
        "user_id": { "type": "string" },
        "note": { "type": "number" },
        "commentaire": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["hotel_id", "user_id", "note"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "users",
      "description": "User profiles."
    },
    "hotels/{hotelId}": {
      "schema": "hotels",
      "description": "Hotels."
    },
    "hotels/{hotelId}/rooms/{roomId}": {
      "schema": "rooms",
      "description": "Internal rooms."
    },
    "reservations/{resId}": {
      "schema": "reservations",
      "description": "Reservations."
    },
    "reviews/{reviewId}": {
      "schema": "reviews",
      "description": "Reviews."
    }
  }
}
